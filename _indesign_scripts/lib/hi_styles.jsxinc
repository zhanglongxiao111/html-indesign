};
HI.ensureObjectStyles = function (doc, objectStyles, report) {
    var out = {};
    for (var name in objectStyles) {
        if (!objectStyles.hasOwnProperty(name)) continue;
        var def = objectStyles[name];
        var style = doc.objectStyles.itemByName(def.name || name);
        try {
            style.name;
        } catch (_) {
            style = doc.objectStyles.add({ name: def.name || name });
            report.counts.objectStyles += 1;
        }
        try { if (def.fillColor) style.fillColor = doc.swatches.itemByName(def.fillColor); } catch (_) {}
        HI.applyFillOpacity(style, def.fillOpacity);
        HI.applyStrokePaint(doc, style, def.strokeColor, def.strokeWeight);
        try { if (def.strokeStyle) style.strokeType = doc.strokeStyles.itemByName(HI.strokeStyleName(def.strokeStyle)); } catch (_) {}
        HI.applyStrokeAlignment(style, def.strokeAlignment);
        HI.applyCornerRadius(style, def.cornerRadius);
        HI.applyOpacity(style, def.opacity); HI.applyBlendMode(style, def.blendMode, report);
        HI.writeProtocolLabels(style, def.labels || [], report, { styleName: def.name || name, styleKind: "object", critical: false });
        out[name] = style;
    }
    return out;
