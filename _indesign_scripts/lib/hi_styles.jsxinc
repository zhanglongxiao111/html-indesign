HI.applyParagraphStyle = function (doc, textFrame, styleName, report) {
    if (!styleName) return;
    try {
        textFrame.parentStory.paragraphs.everyItem().appliedParagraphStyle = doc.paragraphStyles.itemByName(styleName);
    } catch (error) {
        HI.addMessage(report, "warning", "PARAGRAPH_STYLE_APPLY_FAILED", String(error), { styleName: styleName });
    }
};

HI.applyCharacterStyleToRange = function (doc, textFrame, startIndex, length, styleName, report) {
    if (!styleName || length <= 0) return;
    try {
        var range = textFrame.parentStory.characters.itemByRange(startIndex, startIndex + length - 1);
        range.appliedCharacterStyle = doc.characterStyles.itemByName(styleName);
    } catch (error) {
        HI.addMessage(report, "warning", "CHARACTER_STYLE_APPLY_FAILED", String(error), { styleName: styleName });
    }
};

HI.applyObjectStyle = function (doc, pageItem, styleName, report) {
    if (!styleName) return;
    try {
        pageItem.appliedObjectStyle = doc.objectStyles.itemByName(styleName);
    } catch (error) {
        HI.addMessage(report, "warning", "OBJECT_STYLE_APPLY_FAILED", String(error), { styleName: styleName });
    }
};

HI.applyFrameStyle = function (doc, pageItem, styleName, report) {
    if (!styleName || !HI.frameStyles || !HI.frameStyles[styleName]) return;
    var def = HI.frameStyles[styleName];
    var prefs = null;
    try { prefs = pageItem.textFramePreferences; } catch (_) {}
    if (!prefs) return;
    try {
        if (def.inset) {
            prefs.insetSpacing = [
                Number(def.inset.top || 0),
                Number(def.inset.left || 0),
                Number(def.inset.bottom || 0),
                Number(def.inset.right || 0)
            ];
        }
    } catch (error) {
        HI.addMessage(report, "warning", "FRAME_STYLE_APPLY_FAILED", String(error), { styleName: styleName });
    }
};

HI.applyStyleOverride = function (doc, pageItem, override, report) {
    override = override || {};
    try { var fillSwatch = override.fillColor === null ? HI.noneSwatch(doc) : (override.fillColor ? doc.swatches.itemByName(override.fillColor) : null); if (fillSwatch) pageItem.fillColor = fillSwatch; } catch (_) {}
    HI.applyFillOpacity(pageItem, override.fillOpacity);
    HI.applyStrokePaint(doc, pageItem, override.strokeColor, override.strokeWeight);
    HI.applyVectorStrokeStyleOverride(doc, pageItem, override, report);
    HI.applyOpacity(pageItem, override.opacity); HI.applyBlendMode(pageItem, override.blendMode, report);
};

HI.applyItemEffects = function (pageItem, effects, bounds, report) {
    effects = effects || {};
    if (effects.gradientFeather) {
        HI.applyGradientFeather(pageItem, effects.gradientFeather, bounds, report);
    }
};
HI.applyGradientFeather = function (pageItem, def, bounds, report) {
    try {
        var settings = HI.gradientFeatherSettingsFor(pageItem, def);
        settings.applied = true;
        settings.type = GradientType.LINEAR;
        settings.angle = Number(def.angle || 0);
        if (def.start) settings.gradientStart = [Number(def.start.x || 0), Number(def.start.y || 0)];
        try {
            settings.length = Number(HI.gradientFeatherLength(def, bounds));
        } catch (lengthError) {
            if (report) HI.addMessage(report, "warning", "GRADIENT_FEATHER_LENGTH_APPLY_FAILED", String(lengthError), {});
        }
        var stops = def.stops || [];
        HI.resizeGradientFeatherStops(settings, stops.length);
        for (var i = 0; i < stops.length; i++) {
            var stop = HI.gradientFeatherStopAt(settings, i);
            stop.location = Number(stops[i].location);
            stop.opacity = Number(stops[i].opacity);
        }
    } catch (error) {
        if (report) HI.addMessage(report, "warning", "GRADIENT_FEATHER_APPLY_FAILED", String(error), {});
    }
};
HI.gradientFeatherSettingsFor = function (pageItem, def) {
    var scope = String(def && def.scope || "").toLowerCase();
    if (scope === "fill" && pageItem.fillTransparencySettings) {
        try { pageItem.transparencySettings.gradientFeatherSettings.applied = false; } catch (_) {}
        return pageItem.fillTransparencySettings.gradientFeatherSettings;
    }
    return pageItem.transparencySettings.gradientFeatherSettings;
};
HI.gradientFeatherLength = function (def, bounds) { return def && def.length !== null && typeof def.length !== "undefined" ? Number(def.length) : 100; };
HI.gradientFeatherStopCount = function (settings) {
    try { return settings.opacityGradientStops.count(); } catch (_) {}
    try { return settings.opacityGradientStops.length; } catch (_) {}
    return 0;
};
HI.gradientFeatherStopAt = function (settings, index) {
    try { return settings.opacityGradientStops.item(index); } catch (_) {}
    return settings.opacityGradientStops[index];
};
HI.resizeGradientFeatherStops = function (settings, count) {
    while (HI.gradientFeatherStopCount(settings) < count) {
        settings.opacityGradientStops.add();
    }
    while (HI.gradientFeatherStopCount(settings) > count) {
        var lastIndex = HI.gradientFeatherStopCount(settings) - 1;
        HI.gradientFeatherStopAt(settings, lastIndex).remove();
    }
