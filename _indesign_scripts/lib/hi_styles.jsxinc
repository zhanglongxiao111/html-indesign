};
HI.removeDefaultProcessSwatches = function (doc) { var names = ["C=100 M=0 Y=0 K=0", "C=0 M=100 Y=0 K=0", "C=0 M=0 Y=100 K=0", "C=15 M=100 Y=100 K=0", "C=75 M=5 Y=100 K=0", "C=100 M=90 Y=10 K=0"]; for (var i = 0; i < names.length; i++) { try { doc.colors.itemByName(names[i]).remove(); } catch (_) {} } };
HI.hexToRgb = function (value) {
    var match = String(value || "").match(/^#?([0-9a-fA-F]{6})$/);
    if (!match) return null;
    var hex = match[1];
