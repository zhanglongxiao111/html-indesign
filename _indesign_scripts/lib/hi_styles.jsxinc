HI.ensureFrameStyles = function (frameStyles, report) {
    var out = {};
    for (var name in frameStyles) {
        if (!frameStyles.hasOwnProperty(name)) continue;
        out[name] = frameStyles[name];
        if (report && report.counts) report.counts.frameStyles += 1;
    }
    HI.frameStyles = out;
    return out;
};
HI.strokeStyleName = function (value) {
    var text = String(value || ""), key = text.toLowerCase().replace(/^\s+|\s+$/g, "");
    if (!key || key === "solid" || key === "none" || text === String.fromCharCode(23454, 24213)) return "$ID/Solid";
    if (key === "dashed" || key === String.fromCharCode(34394, 32447)) return "$ID/Dashed";
    if (key === "dotted" || key === String.fromCharCode(28857, 32447)) return "$ID/Dotted";
    return text;
};
HI.cssLengthToMm = function (value) {
    var text = String(value || "").replace(/\s+/g, "");
    var match = text.match(/^([+-]?(?:\d+|\d*\.\d+))(mm|pt|px)?/);
    if (!match) return null;
    var amount = Number(match[1]);
    var unit = match[2] || "px";
    if (unit === "mm") return amount;
    if (unit === "pt") return amount * 25.4 / 72;
    return amount * 25.4 / 96;
};
HI.applyCornerRadius = function (target, value) {
    var radius = HI.cssLengthToMm(value);
    if (radius === null || !isFinite(radius) || radius <= 0) return;
    try { target.topLeftCornerOption = CornerOptions.ROUNDED_CORNER; } catch (_) {}
    try { target.topRightCornerOption = CornerOptions.ROUNDED_CORNER; } catch (_) {}
    try { target.bottomRightCornerOption = CornerOptions.ROUNDED_CORNER; } catch (_) {}
    try { target.bottomLeftCornerOption = CornerOptions.ROUNDED_CORNER; } catch (_) {}
    try { target.topLeftCornerRadius = String(radius) + "mm"; } catch (_) {}
    try { target.topRightCornerRadius = String(radius) + "mm"; } catch (_) {}
    try { target.bottomRightCornerRadius = String(radius) + "mm"; } catch (_) {}
    try { target.bottomLeftCornerRadius = String(radius) + "mm"; } catch (_) {}
};
HI.ensureTableStyles = function (doc, tableStyles, report) {
    var out = {};
    for (var name in tableStyles) {
        if (!tableStyles.hasOwnProperty(name)) continue;
        var def = tableStyles[name];
        var style = doc.tableStyles.itemByName(def.name || name);
        try {
            style.name;
        } catch (_) {
            try {
                style = doc.tableStyles.add({ name: def.name || name });
                report.counts.tableStyles += 1;
            } catch (error) {
                HI.addMessage(report, "warning", "TABLE_STYLE_CREATE_FAILED", String(error), { name: name });
            }
        }
        HI.writeProtocolLabels(style, def.labels || [], report, { styleName: def.name || name, styleKind: "table", critical: false });
        out[name] = style;
    }
    return out;
