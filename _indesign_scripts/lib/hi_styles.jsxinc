HI.applyOpacity = function (target, opacity) {
    if (opacity === null || typeof opacity === "undefined") return;
    var value = HI.opacityPercent(opacity);
    try { target.transparencySettings.blendingSettings.opacity = value; } catch (_) {}
};
HI.applyFillOpacity = function (target, opacity) {
    if (opacity === null || typeof opacity === "undefined") return;
    try { target.fillTransparencySettings.blendingSettings.opacity = HI.opacityPercent(opacity); } catch (_) {}
};
HI.opacityPercent = function (opacity) {
    var value = Number(opacity);
    if (!isFinite(value)) return 100;
    if (value <= 1) value = value * 100;
    if (value < 0) value = 0;
    if (value > 100) value = 100;
    return value;
};
