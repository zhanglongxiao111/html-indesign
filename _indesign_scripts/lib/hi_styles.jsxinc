HI.assignCharacterStyleExtras = function (style, def) {
    var decoration = String(def.textDecoration || "").toLowerCase();
    var position = String(def.verticalPosition || "").toLowerCase(), capitalization = String(def.capitalization || "").toLowerCase();
    try { if (decoration.indexOf("underline") >= 0) style.underline = true; if (decoration.indexOf("line-through") >= 0) style.strikeThru = true; } catch (_) {}
    try { if (position === "super" || position === "sup") style.position = Position.SUPERSCRIPT; if (position === "sub") style.position = Position.SUBSCRIPT; } catch (_) {}
    try { if (capitalization === "allcaps") style.capitalization = Capitalization.ALL_CAPS; if (capitalization === "smallcaps") style.capitalization = Capitalization.SMALL_CAPS; } catch (_) {}
};
HI.ptValue = function (value) { return String(Number(value)) + "pt"; };
HI.justificationFor = function (value) {
    var key = String(value || "").toLowerCase();
    if (key === "center") return Justification.CENTER_ALIGN;
    if (key === "right" || key === "end") return Justification.RIGHT_ALIGN;
    if (key === "justify") return Justification.FULLY_JUSTIFIED;
